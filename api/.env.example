# Application
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# JWT (defaults shown; uncomment to override)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ALGORITHM=HS256

# Database
# PostgreSQL (Render or any PostgreSQL instance):
DATABASE_URL=postgresql://user:password@host:port/dbname
# SQLite for offline local development only:
# DATABASE_URL=sqlite:///./gps_local.db

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Stripe (Test Mode - Use your test keys for development)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_MONTHLY=price_test_monthly_plan_id
STRIPE_PRICE_YEARLY=price_test_yearly_plan_id

# Resend (Email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=no-reply@email.giftpassionstory.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Zapier — Disciples Made's central Kit account (set in Render UI in prod).
# Leave unset locally; each call site no-ops if its URL is missing.
# ZAPIER_NEW_ACCOUNT_URL=https://hooks.zapier.com/hooks/catch/.../...
# ZAPIER_TOOLKIT_ACTIVATED_URL=https://hooks.zapier.com/hooks/catch/.../...
# ZAPIER_TOOLKIT_CANCELED_URL=https://hooks.zapier.com/hooks/catch/.../...
# ZAPIER_USER_DELETED_URL=https://hooks.zapier.com/hooks/catch/.../...
