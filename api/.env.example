# Application
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database
# PostgreSQL (Render or any PostgreSQL instance):
DATABASE_URL=postgresql://user:password@host:port/dbname
# SQLite for offline local development only:
# DATABASE_URL=sqlite:///./gps_local.db

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Stripe (Test Mode - Use your test keys for development)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_MONTHLY=price_test_monthly_plan_id
STRIPE_PRICE_YEARLY=price_test_yearly_plan_id

# Resend (Email)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@giftpassionstory.com

# Frontend URL
FRONTEND_URL=http://localhost:5173
